# ============================================================================
# THESIS PROJECT .gitignore
# Python + Data Science + Streamlit Project
# ============================================================================

# ============================================================================
# 1. PYTHON GENERAL
# ============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints
*/.ipynb_checkpoints/*

# IPython
profile_default/
ipython_config.py

# pyenv
.python-version

# Virtual Environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# ============================================================================
# 2. DATA FILES
# ============================================================================

# Raw data files (large, reproducible)
data/raw/**
!data/raw/
!data/raw/**/README.md

# Processed data files
data/processed/**
!data/processed/
!data/processed/**/README.md

# Backup data files
data/*.tar.gz
data/*.zip

# ============================================================================
# 3. MODELS AND OUTPUTS
# ============================================================================

# Trained ML models
*.pkl
*.joblib
*.h5
*.model

# Output directory
outputs/**
!outputs/
!outputs/**/README.md
results/
figures/

# Streamlit cache
.streamlit/

# ============================================================================
# 4. IDE AND EDITORS
# ============================================================================

# VS Code
.vscode/

# PyCharm
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc

# ============================================================================
# 5. OPERATING SYSTEM
# ============================================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
.directory
.Trash-*

# ============================================================================
# 6. LOGS AND TEMPORARY FILES
# ============================================================================

*.log
logs/
*.log.*
*.tmp
*.temp
*.bak

# ============================================================================
# 7. SECURITY
# ============================================================================

# API keys and credentials
.env
.env.local
.env.*.local
secrets.json
credentials.json
config.ini

# SSH keys
*.pem
*.key
id_rsa
id_rsa.pub

# ============================================================================
# 8. PROJECT-SPECIFIC
# ============================================================================

# StatsBomb data (license restrictions)
data/statsbomb/

# Large model files
models/*.pkl
models/*.joblib

# Streamlit secrets
.streamlit/secrets.toml

# Experiment tracking
mlruns/
.mlflow/

# Node.js (diagram generation)
node_modules/

# Application cache
src/app/cache/**
!src/app/cache/
!src/app/cache/.gitignore
src/app/joblib/

# Generated script data
scripts/**/data/**
!scripts/**/data/
!scripts/**/data/**/README.md

# ============================================================================
# 9. DOCUMENTATION BUILDS
# ============================================================================

# Sphinx documentation
docs/_build/
docs/.doctrees/

# LaTeX
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.out
*.toc
*.synctex.gz

# ============================================================================
# 10. BACKUP AND ARCHIVE
# ============================================================================

*.backup
backup_*/
old_*/
*.tar.gz
*.zip
*.rar
*.7z

# ============================================================================
# EXCEPTIONS (these files CAN be committed)
# ============================================================================

# Small sample datasets
!data/sample/
!data/examples/*.csv

# Model evaluation results (small JSONs)
!outputs/model_metrics.json

# Thesis figures
!outputs/figures/thesis_*.png

# README files
!**/README.md
